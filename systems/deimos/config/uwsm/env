DOTFILES_REPO_ROOT="${repo_root:-$HOME/.config/nix-dotfiles}"
export DOTFILES_HOST_BIN="$DOTFILES_REPO_ROOT/systems/deimos/bin"

if [ -d "$DOTFILES_HOST_BIN" ]; then
  case ":$PATH:" in
    *":$DOTFILES_HOST_BIN:"*) ;;
    *) export PATH="$DOTFILES_HOST_BIN:$PATH" ;;
  esac
fi

nix_profile="$HOME/.nix-profile"
nix_state_profile="${XDG_STATE_HOME:-$HOME/.local/state}/nix/profile"
export XDG_DATA_DIRS="$nix_state_profile/share:$nix_profile/share:/nix/var/nix/profiles/default/share:${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
export XCURSOR_PATH="$HOME/.local/share/icons:$HOME/.icons:$nix_state_profile/share/icons:$nix_profile/share/icons:/nix/var/nix/profiles/default/share/icons:${XCURSOR_PATH:-/usr/share/icons}"

export MOZ_ENABLE_WAYLAND=1
export ELECTRON_OZONE_PLATFORM_HINT=auto
export SDL_VIDEODRIVER=wayland
export CLUTTER_BACKEND=wayland
export GTK_USE_PORTAL=1
export QT_QPA_PLATFORMTHEME=qt5ct
export QT_STYLE_OVERRIDE=kvantum
export SSH_AUTH_SOCK="$XDG_RUNTIME_DIR/ssh-agent"
