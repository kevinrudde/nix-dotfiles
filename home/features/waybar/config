{
  "layer": "top",
  "position": "top",
  "height": 36,
  "spacing": 8,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "hyprland/submap"
  ],
  "modules-center": [
    "hyprland/window"
  ],
  "modules-right": [
    "tray",
    "idle_inhibitor",
    "pulseaudio",
    "backlight",
    "cpu",
    "memory",
    "custom/power-usage",
    "custom/notification",
    "battery",
    "network",
    "clock",
    "custom/power"
  ],
  "custom/launcher": {
    "format": "´îè",
    "tooltip": "Open launcher",
    "on-click": "uwsm app -- fuzzel"
  },
  "hyprland/workspaces": {
    "format": "{name}",
    "sort-by": "name",
    "on-click": "activate"
  },
  "hyprland/submap": {
    "format": "<span style=\"italic\">{}</span>",
    "max-length": 18,
    "tooltip": false
  },
  "hyprland/window": {
    "format": "{}",
    "separate-outputs": true,
    "max-length": 72,
    "rewrite": {
      "": "Desktop"
    }
  },
  "tray": {
    "icon-size": 18,
    "spacing": 6,
    "show-passive-items": true
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "´ü«",
      "deactivated": "´ü░"
    },
    "tooltip-format-activated": "Idle inhibitor active",
    "tooltip-format-deactivated": "Idle inhibitor inactive"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´èö",
    "format-muted": "muted ´æĞ",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´ÇÑ",
      "hands-free": "´ûÉ",
      "headset": "´ûÉ",
      "phone": "´éò",
      "portable": "´éò",
      "car": "´å╣",
      "default": [
        "´ÇĞ",
        "´Çğ",
        "´Ç¿"
      ]
    },
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "¾░âŞ",
      "¾░âş",
      "¾░âá"
    ],
    "on-scroll-up": "brightnessctl set 5%+",
    "on-scroll-down": "brightnessctl set 5%-"
  },
  "cpu": {
    "format": "´ïø {usage}%",
    "interval": 3,
    "tooltip": true
  },
  "memory": {
    "format": "¯┐à {}%",
    "interval": 3
  },
  "custom/power-usage": {
    "exec": "$HOME/.config/waybar/scripts/power-usage.sh",
    "return-type": "json",
    "interval": 5
  },
  "custom/notification": {
    "tooltip": true,
    "format": "{0} {icon}",
    "format-icons": {
      "notification": "¾░éÜ",
      "none": "¾░é£",
      "dnd-notification": "¾░éø",
      "dnd-none": "¾░¬æ",
      "inhibited-notification": "¾░éø",
      "inhibited-none": "¾░¬æ",
      "dnd-inhibited-notification": "¾░éø",
      "dnd-inhibited-none": "¾░¬æ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "battery": {
    "states": {
      "good": 80,
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% ´âğ",
    "format-plugged": "{capacity}% ´çĞ",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "´ëä",
      "´ëâ",
      "´ëé",
      "´ëü",
      "´ëÇ"
    ]
  },
  "network": {
    "format-wifi": "{signalStrength}% ´ç½",
    "format-ethernet": "¾░êÇ",
    "format-linked": "{ifname} ´æî",
    "format-disconnected": "´ü▒",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected"
  },
  "clock": {
    "format": "{:%a %d %b  %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "custom/power": {
    "format": "´Çæ",
    "tooltip": "Power menu",
    "on-click": "$HOME/.config/waybar/scripts/power-menu.sh"
  }
}
