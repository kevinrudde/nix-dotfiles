{
  "manifest_version": 3,
  "name": "Slack Open Links External",
  "version": "1.0.0",
  "description": "Open links clicked in the Slack web app with the system default browser.",
  "key": "",
  "permissions": [
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://app.slack.com/*",
    "https://*.slack.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.slack.com/*",
        "https://*.slack.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://app.slack.com/*",
        "https://*.slack.com/*"
      ],
      "js": [
        "page.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
