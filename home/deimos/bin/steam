#!/usr/bin/env bash
set -euo pipefail

uid="$(id -u)"
runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$uid}"

exec env -i \
  HOME="${HOME:-/home/kevin}" \
  USER="${USER:-kevin}" \
  LOGNAME="${LOGNAME:-${USER:-kevin}}" \
  PATH="/usr/local/bin:/usr/bin:/bin" \
  XDG_RUNTIME_DIR="$runtime_dir" \
  DISPLAY="${DISPLAY:-:0}" \
  WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}" \
  DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=$runtime_dir/bus}" \
  XDG_CURRENT_DESKTOP="${XDG_CURRENT_DESKTOP:-Hyprland}" \
  XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}" \
  LANG="${LANG:-en_US.UTF-8}" \
  /usr/bin/steam "$@"
